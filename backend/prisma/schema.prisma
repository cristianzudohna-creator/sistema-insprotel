generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  SUPERVISOR
  PREVENCION
  CONDUCTOR
  TECNICO
}

enum VehicleCheckStatus {
  PENDIENTE
  COMPLETADO
  OBSERVADO
}

enum CheckItemStatus {
  BUENO
  MALO
  NO_APLICA
}

enum HarnessCheckStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum HarnessItemStatus {
  SI
  NO
  NO_APLICA
}

enum LadderCheckStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum LadderItemStatus {
  BUENO
  MALO
  NO_APLICA
}

enum ScissorLadderCheckStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum ScissorLadderItemStatus {
  BUENO
  MALO
  NO_APLICA
}

enum ToolsEppCheckStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum ToolsEppItemStatus {
  BUENO
  MALO
  NO_APLICA
}

enum ToolsDriverCheckStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum ToolsDriverItemStatus {
  BUENO
  MALO
  NO_APLICA
}

enum DocumentStatus {
  VIGENTE
  VENCIDA
}

enum SafetyTalkStatus {
  BORRADOR
  PENDIENTE_FIRMAS
  COMPLETADA
  ENVIADA_REVISION
}

enum SafetyTalkCreatorRole {
  SUPERADMIN
  TECNICO
  CONDUCTOR
  SUPERVISOR
  PREVENCION
}

model User {
  id       Int     @id @default(autoincrement())
  rut      String? @unique
  name     String
  email    String? @unique
  password String
  role     Role

  isActive           Boolean @default(true)
  mustChangePassword Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicleChecks             VehicleCheckList[]
  safetyTalks               SafetyTalk[]
  safetyTalkParticipations  SafetyTalkParticipant[]
  harnessChecks             HarnessCheck[]
  ladderChecks              LadderCheck[]
  scissorLadderChecks       ScissorLadderCheck[]
  toolsEppChecks            ToolsEppCheck[]
  toolsDriverChecks         ToolsDriverCheck[]
  notifications             Notification[]
  fcmTokens                 UserFcmToken[]
}

model Vehicle {
  id Int @id @default(autoincrement())

  patent       String  @unique
  vehicleType  String?
  vehicleModel String?
  company      String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleCheckList {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime

  patent              String
  mileage             Int?
  maintenanceUpToDate String?

  vehicleType  String?
  vehicleModel String?

  driverName         String
  supervisorName     String?
  driverSignatureUrl String?

  technicalReview       DateTime?
  technicalReviewStatus DocumentStatus?

  gasEmissionReview       DateTime?
  gasEmissionReviewStatus DocumentStatus?

  driverLicenseExpiration DateTime?
  driverLicenseStatus     DocumentStatus?

  circulationPermitExpiration DateTime?
  circulationPermitStatus     DocumentStatus?

  mandatoryInsuranceExpiration DateTime?
  mandatoryInsuranceStatus     DocumentStatus?

  generalObservation String?

  status VehicleCheckStatus @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items  VehicleCheckItem[]
  photos VehicleCheckPhoto[]
}

model VehicleCheckItem {
  id Int @id @default(autoincrement())

  itemName String

  status      CheckItemStatus?
  observation String?
  photoUrl    String?

  createdAt DateTime @default(now())

  vehicleCheckListId Int
  vehicleCheckList   VehicleCheckList @relation(fields: [vehicleCheckListId], references: [id], onDelete: Cascade)
}

model VehicleCheckPhoto {
  id Int @id @default(autoincrement())

  imageUrl String

  createdAt DateTime @default(now())

  vehicleCheckListId Int
  vehicleCheckList   VehicleCheckList @relation(fields: [vehicleCheckListId], references: [id], onDelete: Cascade)
}

model SafetyTalk {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  areaLocationInstallation String?
  meetingTime              String?

  workOrderProject   String?
  workPermitActivity String?

  worksToDo            String?
  foremanOrBrigadeName String?
  foremanCompany       String?
  peopleCount          Int?

  workTypes        String?
  significantRisks String?
  analyzedAccident String?

  controlMeasure1  String?
  controlMeasure2  String?
  controlMeasure3  String?
  controlMeasure4  String?
  controlMeasure5  String?
  controlMeasure6  String?
  controlMeasure7  String?
  controlMeasure8  String?
  controlMeasure9  String?
  controlMeasure10 String?
  controlMeasure11 String?
  controlMeasure12 String?

  creatorRole SafetyTalkCreatorRole?
  status      SafetyTalkStatus @default(PENDIENTE_FIRMAS)

  completedAt DateTime?

  createdByName         String?
  createdByRut          String?
  createdBySignatureUrl String?

  sentToSupervisorAt DateTime?
  sentToPreventionAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  participants SafetyTalkParticipant[]
  photos       SafetyTalkPhoto[]
}

model SafetyTalkParticipant {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  name String
  rut  String?

  compliesRest Boolean?
  signatureUrl  String?
  signedAt      DateTime?

  createdAt DateTime @default(now())

  safetyTalkId Int
  safetyTalk   SafetyTalk @relation(fields: [safetyTalkId], references: [id], onDelete: Cascade)
}

model SafetyTalkPhoto {
  id Int @id @default(autoincrement())

  imageUrl String

  createdAt DateTime @default(now())

  safetyTalkId Int
  safetyTalk   SafetyTalk @relation(fields: [safetyTalkId], references: [id], onDelete: Cascade)
}

model HarnessCheck {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  contract                String?
  technicianName          String?
  mobile                  String?
  supervisorInspectorName String?
  zone                    String?

  technicianSignatureUrl String?
  supervisorSignatureUrl String?

  status HarnessCheckStatus @default(PENDIENTE)

  generalObservation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items HarnessCheckItem[]
}

model HarnessCheckItem {
  id Int @id @default(autoincrement())

  description String
  status      HarnessItemStatus?
  observation String?

  createdAt DateTime @default(now())

  harnessCheckId Int
  harnessCheck   HarnessCheck @relation(fields: [harnessCheckId], references: [id], onDelete: Cascade)
}

model LadderCheck {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  contract       String?
  technicianName String?
  mobile         String?
  inspectorName  String?
  zone           String?

  technicianSignatureUrl String?
  inspectorSignatureUrl  String?

  status LadderCheckStatus @default(PENDIENTE)

  generalObservation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items  LadderCheckItem[]
  photos LadderCheckPhoto[]
}

model LadderCheckItem {
  id Int @id @default(autoincrement())

  section     String
  description String
  status      LadderItemStatus?
  observation String?

  createdAt DateTime @default(now())

  ladderCheckId Int
  ladderCheck   LadderCheck @relation(fields: [ladderCheckId], references: [id], onDelete: Cascade)
}

model LadderCheckPhoto {
  id Int @id @default(autoincrement())

  imageUrl String

  createdAt DateTime @default(now())

  ladderCheckId Int
  ladderCheck   LadderCheck @relation(fields: [ladderCheckId], references: [id], onDelete: Cascade)
}

model ScissorLadderCheck {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  contract       String?
  technicianName String?
  mobile         String?
  inspectorName  String?
  zone           String?

  technicianSignatureUrl String?
  inspectorSignatureUrl  String?

  status ScissorLadderCheckStatus @default(PENDIENTE)

  generalObservation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items  ScissorLadderCheckItem[]
  photos ScissorLadderCheckPhoto[]
}

model ScissorLadderCheckItem {
  id Int @id @default(autoincrement())

  section     String
  description String
  status      ScissorLadderItemStatus?
  observation String?

  createdAt DateTime @default(now())

  scissorLadderCheckId Int
  scissorLadderCheck   ScissorLadderCheck @relation(fields: [scissorLadderCheckId], references: [id], onDelete: Cascade)
}

model ScissorLadderCheckPhoto {
  id Int @id @default(autoincrement())

  imageUrl String

  createdAt DateTime @default(now())

  scissorLadderCheckId Int
  scissorLadderCheck   ScissorLadderCheck @relation(fields: [scissorLadderCheckId], references: [id], onDelete: Cascade)
}

model ToolsEppCheck {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  contract                String?
  technicianName          String?
  mobile                  String?
  supervisorInspectorName String?
  zone                    String?

  technicianSignatureUrl String?
  inspectorSignatureUrl  String?

  status ToolsEppCheckStatus @default(PENDIENTE)

  generalObservation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items ToolsEppCheckItem[]
}

model ToolsEppCheckItem {
  id Int @id @default(autoincrement())

  number Int?
  name   String

  quantity    String?
  status      ToolsEppItemStatus?
  observation String?

  createdAt DateTime @default(now())

  toolsEppCheckId Int
  toolsEppCheck   ToolsEppCheck @relation(fields: [toolsEppCheckId], references: [id], onDelete: Cascade)
}

model ToolsDriverCheck {
  id Int @id @default(autoincrement())

  folio String?
  date  DateTime @default(now())

  contract                String?
  driverName              String?
  mobile                  String?
  supervisorInspectorName String?
  zone                    String?
  heightExamExpiration    String?

  driverSignatureUrl    String?
  inspectorSignatureUrl String?

  status ToolsDriverCheckStatus @default(PENDIENTE)

  generalObservation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items ToolsDriverCheckItem[]
}

model ToolsDriverCheckItem {
  id Int @id @default(autoincrement())

  number      Int?
  name        String
  quantity    String?
  status      ToolsDriverItemStatus?
  observation String?

  createdAt DateTime @default(now())

  toolsDriverCheckId Int
  toolsDriverCheck   ToolsDriverCheck @relation(fields: [toolsDriverCheckId], references: [id], onDelete: Cascade)
}

model Notification {
  id Int @id @default(autoincrement())

  title   String
  message String
  url     String?
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFcmToken {
  id Int @id @default(autoincrement())

  token String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}